{
  "name": "airirang-builder",
  "version": "0.1.0",
  "description": "AI-driven precise Minecraft building via 3D mesh voxelization + /fill greedy meshing + datapack. MCP server. NOT AN OFFICIAL MINECRAFT PRODUCT. NOT APPROVED BY OR ASSOCIATED WITH MOJANG OR MICROSOFT.",
  "license": "AGPL-3.0-or-later",
  "private": false,
  "type": "module",
  "author": "AIrirang Studio <skseo@airirang.co.kr>",
  "homepage": "https://github.com/airirang/airirang-builder#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/airirang/airirang-builder.git"
  },
  "bugs": {
    "url": "https://github.com/airirang/airirang-builder/issues"
  },
  "keywords": [
    "minecraft",
    "mcp",
    "voxelizer",
    "ai",
    "building",
    "claude",
    "airirang"
  ],
  "files": [
    "dist/",
    "src/presets/data/",
    "README.md",
    "LICENSE",
    "LICENSE-COMMERCIAL.md"
  ],
  "bin": {
    "airirang-builder": "dist/cli/bin.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./voxelizer": {
      "types": "./dist/voxelizer/index.d.ts",
      "import": "./dist/voxelizer/index.js"
    },
    "./greedy-meshing": {
      "types": "./dist/greedy-meshing/index.d.ts",
      "import": "./dist/greedy-meshing/index.js"
    },
    "./palette": {
      "types": "./dist/palette/index.d.ts",
      "import": "./dist/palette/index.js"
    },
    "./datapack": {
      "types": "./dist/datapack/index.d.ts",
      "import": "./dist/datapack/index.js"
    },
    "./mcp": {
      "types": "./dist/mcp/index.d.ts",
      "import": "./dist/mcp/index.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/cli/bin.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint --no-error-on-unmatched-pattern \"src/**/*.ts\" \"tests/**/*.ts\"",
    "format": "prettier --write \"src/**/*.ts\" \"tests/**/*.ts\"",
    "prepublishOnly": "npm run build && npm test"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@gltf-transform/core": "^4.3.0",
    "@gltf-transform/functions": "^4.3.0",
    "@modelcontextprotocol/sdk": "^1.0.0",
    "commander": "^12.0.0",
    "jimp": "^1.6.1",
    "obj-file-parser": "^0.6.2",
    "three": "^0.169.0",
    "tsx": "^4.19.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/node": "^22.0.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "eslint": "^9.0.0",
    "globals": "^17.6.0",
    "prettier": "^3.3.0",
    "typescript": "^5.6.0",
    "typescript-eslint": "^8.59.4",
    "vitest": "^2.1.0"
  }
}
